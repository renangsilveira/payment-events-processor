      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "payment_outbox_pending_count{application=\"payment-events-processor\"}",
          "legendFormat": "Pending outbox events"
        }
      ],
      "title": "Outbox Lag (Pending Events)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "payment_outbox_failed_count{application=\"payment-events-processor\"}",
          "legendFormat": "Failed outbox events (DLQ candidates)"
        }
      ],
      "title": "DLQ Rate (Failed Outbox Events)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(spring_kafka_listener_seconds_count{application=\"payment-events-processor\"}[1m])",
          "legendFormat": "Consumer throughput (messages/sec)"
        }
      ],
      "title": "Consumer Throughput (payment.events.v1)",
      "type": "timeseries"
    }
